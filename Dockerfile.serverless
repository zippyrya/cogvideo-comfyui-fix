# Stage 1: Builder - Install dependencies and download models
FROM nvidia/cuda:12.1-devel-ubuntu22.04 AS builder

# Install system dependencies and Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    git \
    wget \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt /tmp/requirements.txt
RUN pip3 install --no-cache-dir -r /tmp/requirements.txt

# Download CogVideoX-5b model weights at build time
RUN python3 -c "from huggingface_hub import snapshot_download; snapshot_download('THUDM/CogVideoX-5b', local_dir='/models/CogVideoX-5b', local_dir_use_symlinks=False)"

# Download IPAdapter and CLIP Vision models
RUN python3 -c "from huggingface_hub import hf_hub_download; hf_hub_download('h94/IP-Adapter', 'ipadapter_sdxl.safetensors', local_dir='/models/IPAdapter'); hf_hub_download('h94/IP-Adapter', 'image_encoder.safetensors', local_dir='/models/IPAdapter')"

# Download CLIP Vision
RUN python3 -c "from huggingface_hub import hf_hub_download; hf_hub_download('openai/clip-vit-large-patch14', 'pytorch_model.bin', local_dir='/models/CLIP', filename='clip_vision_g.safetensors')"

# Download ControlNet models
RUN python3 -c "from huggingface_hub import hf_hub_download; hf_hub_download('TheMistoAI/CogVideoX-ControlNet', 'cogvideox-controlnet-pose.safetensors', local_dir='/models/ControlNet')"

# Stage 2: Runtime - Minimal CUDA runtime
FROM nvidia/cuda:12.1-runtime-ubuntu22.04 AS runtime

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy Python packages from builder
COPY --from=builder /usr/local/lib/python3.10/dist-packages /usr/local/lib/python3.10/dist-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy pre-downloaded models
COPY --from=builder /models /models

# Create symlinks for ComfyUI compatibility
RUN mkdir -p /workspace/ComfyUI/models && \
    ln -sf /models/CogVideoX-5b /workspace/ComfyUI/models/CogVideo && \
    ln -sf /models/IPAdapter /workspace/ComfyUI/models/IPAdapter && \
    ln -sf /models/CLIP /workspace/ComfyUI/models/CLIP && \
    ln -sf /models/ControlNet /workspace/ComfyUI/models/ControlNet

# Set working directory
WORKDIR /app

# Copy handler
COPY handler.py /app/handler.py

# Verify model paths
RUN ls -la /models/CogVideoX-5b/ && ls -la /models/IPAdapter/ && ls -la /models/CLIP/ && ls -la /models/ControlNet/

# RunPod serverless entrypoint
CMD ["python3", "-u", "/app/handler.py"]
